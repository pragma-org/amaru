#!/usr/bin/env node

import { createReadStream } from 'node:fs';
import { createInterface } from 'node:readline';

process.stdout.on('error', error => {
  if (error.code === 'EPIPE') {
    process.exit(0);
  }

  throw error;
});

function printUsage() {
  console.error(`Usage:
  node scripts/normalize-traces trace.log

The command extracts TRACE span families from an Amaru log and writes them as
normalized JSONL records suitable for demo trace baselines.`);
}

const [inputFile] = process.argv.slice(2);

if (process.argv.includes('--help') || process.argv.includes('-h')) {
  printUsage();
  process.exit(0);
}

if (!inputFile) {
  printUsage();
  process.exit(2);
}

const reader = createInterface({
  input: createReadStream(inputFile),
  crlfDelay: Infinity,
});

for await (const rawLine of reader) {
  const line = rawLine.trim();
  if (!line.startsWith('{')) continue;

  let obj;
  try {
    obj = JSON.parse(line);
  } catch {
    continue;
  }

  if (!obj || typeof obj !== 'object' || typeof obj.target !== 'string') {
    continue;
  }

  if ('level' in obj && obj.level !== 'TRACE') {
    continue;
  }

  if (typeof obj.span?.name !== 'string') {
    continue;
  }

  process.stdout.write(`${JSON.stringify({
    target: obj.target,
    span: { name: obj.span.name },
  })}\n`);
}