#!/usr/bin/env bash

set -u

exitWithUsage () {
  echo -e "\033[1;31mError: missing argument(s)!\033[00m\n"
  echo -e "\033[1;32mUsage:\033[00m\n    $0 BUILD_PROFILE TARGET_EPOCH\n"
  echo -e "\033[1mExamples:\033[00m \n    $0 release 173"
  exit 1
}

if [ $# != 2 ]; then
    exitWithUsage
fi

BUILD_PROFILE=$1
if [ -z "$BUILD_PROFILE" ]; then
  exitWithUsage
fi

TARGET_EPOCH=$2
if [ -z "$TARGET_EPOCH" ]; then
  exitWithUsage
fi

echo -e "      \033[1;32mTarget\033[00m epoch $TARGET_EPOCH"
cargo build --profile $BUILD_PROFILE --bin amaru

export AMARU_TRACE="${AMARU_TRACE:-amaru=info}"

function run() {
  /bin/sh -c "echo exitPID=\$\$; exec cargo run --profile $BUILD_PROFILE -- --with-json-traces run"
}

function prefilterWatchLines() {
  grep --line-buffered -E '^exitPID=|"level":"INFO"'
}

function watchTargetEpoch() {
  jq -Rr '
    if startswith("exitPID=") then
      "pid\t" + ltrimstr("exitPID=")
    else
      (try fromjson catch empty)
      | select(.level == "INFO")
      | select(.fields.message == "exit")
      | select(.target == "amaru::ledger::state")
      | select(.span.name == "epoch_transition")
      | "epoch\t" + ((.span.into // .into) | tostring)
    end
  '
}

function targetEpochEvents() {
  run \
    | tee /dev/stderr \
    | prefilterWatchLines \
    | watchTargetEpoch
}

function handleTargetEpoch() {
  local ended=false
  local pid=""

  while IFS=$'\t' read -r kind value; do
    case "$kind" in
      pid)
        pid="$value"
        echo "PID=$pid (me=$$)"
        ;;
      epoch)
        echo "Epoch $value"
        if [ "$value" -eq "$TARGET_EPOCH" ]; then
          echo "Target epoch reached, stopping the process."
          kill -INT "$pid"
          ended=true
          break
        fi
        ;;
    esac
  done < <(targetEpochEvents)

  printf '%s\n' "$ended"
}

ENDED=$(handleTargetEpoch)

# return value needs to reflect whether target epoch was reached
echo "ENDED=$ENDED"
test "$ENDED" = true
