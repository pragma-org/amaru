#!/usr/bin/env node

import { createReadStream, readFileSync, writeFileSync } from 'node:fs';
import { createInterface } from 'node:readline';

const CONTRACT_FORMAT_VERSION = 'amaru-trace-contract@1';

function formatFamily(family) {
  const bits = [`target=${family.target}`];
  if (family.spanName) bits.push(`span=${family.spanName}`);
  return bits.join(' | ');
}

function makeFamilyKey(family) {
  return [family.target, family.spanName ?? ''].join('\u001f');
}

function getOrCreateFamily(state, family) {
  const key = makeFamilyKey(family);
  let entry = state.traceDescriptors.get(key);
  if (!entry) {
    entry = {
      ...family,
      count: 0,
      compressedPositions: [],
    };
    state.traceDescriptors.set(key, entry);
  }
  return entry;
}

function createState(filePath) {
  return {
    filePath,
    totalJsonLines: 0,
    traceDescriptors: new Map(),
    compressedOrder: [],
    lastCompressedKey: null,
    contractAnchors: null,
    source: null,
  };
}

function normalizeFamilyDescriptor(value, context) {
  if (!value || typeof value !== 'object' || Array.isArray(value)) {
    throw new Error(`${context} must be an object`);
  }

  if (typeof value.target !== 'string' || value.target.length === 0) {
    throw new Error(`${context}.target must be a non-empty string`);
  }

  if ('spanName' in value && typeof value.spanName !== 'string') {
    throw new Error(`${context}.spanName must be a string when provided`);
  }

  return {
    target: value.target,
    spanName: typeof value.spanName === 'string' ? value.spanName : '',
  };
}

function serializeFamily(family) {
  const serialized = { target: family.target };
  if (family.spanName) {
    serialized.spanName = family.spanName;
  }
  return serialized;
}

async function loadTraceState(filePath) {
  const state = createState(filePath);
  const stream = createReadStream(filePath);
  const reader = createInterface({ input: stream, crlfDelay: Infinity });

  for await (const rawLine of reader) {
    const line = rawLine.trim();
    if (!line.startsWith('{')) continue;

    let obj;
    try {
      obj = JSON.parse(line);
    } catch {
      continue;
    }

    if (!obj || typeof obj !== 'object' || typeof obj.target !== 'string') {
      continue;
    }

    if ('level' in obj && obj.level !== 'TRACE') {
      continue;
    }

    if (typeof obj.span?.name !== 'string') {
      continue;
    }

    state.totalJsonLines += 1;

    const family = {
      target: obj.target,
      spanName: typeof obj.span?.name === 'string' ? obj.span.name : '',
    };

    const entry = getOrCreateFamily(state, family);
    const familyKey = makeFamilyKey(family);
    entry.count += 1;

    if (state.lastCompressedKey !== familyKey) {
      entry.compressedPositions.push(state.compressedOrder.length);
      state.compressedOrder.push(familyKey);
      state.lastCompressedKey = familyKey;
    }
  }

  return state;
}

function failInvalidContract(contractPath, message) {
  console.error(`Invalid trace contract ${contractPath}: ${message}`);
  process.exit(2);
}

function loadTraceContract(filePath) {
  let parsed;
  try {
    parsed = JSON.parse(readFileSync(filePath, 'utf8'));
  } catch (error) {
    failInvalidContract(filePath, error instanceof Error ? error.message : String(error));
  }

  if (parsed == null || Array.isArray(parsed) || typeof parsed !== 'object') {
    failInvalidContract(filePath, 'top-level JSON value must be an object');
  }

  if (parsed.format !== CONTRACT_FORMAT_VERSION) {
    failInvalidContract(
      filePath,
      `"format" must be "${CONTRACT_FORMAT_VERSION}"`,
    );
  }

  if (!Array.isArray(parsed.traceDescriptors)) {
    failInvalidContract(filePath, '"traceDescriptors" must be an array');
  }

  if (!Array.isArray(parsed.anchors)) {
    failInvalidContract(filePath, '"anchors" must be an array');
  }

  const state = createState(filePath);
  state.source = parsed.source ?? null;

  for (const [index, rawFamily] of parsed.traceDescriptors.entries()) {
    const family = normalizeFamilyDescriptor(rawFamily, `traceDescriptors[${index}]`);
    const key = makeFamilyKey(family);
    if (state.traceDescriptors.has(key)) {
      failInvalidContract(filePath, `traceDescriptors[${index}] duplicates an existing trace descriptor`);
    }

    state.traceDescriptors.set(key, {
      ...family,
      count: 0,
      compressedPositions: [],
    });
  }

  for (const [index, rawAnchor] of parsed.anchors.entries()) {
    const family = normalizeFamilyDescriptor(rawAnchor, `anchors[${index}]`);
    const key = makeFamilyKey(family);
    const entry = state.traceDescriptors.get(key);
    if (!entry) {
      failInvalidContract(filePath, `anchors[${index}] must reference a trace descriptor from "traceDescriptors"`);
    }
    entry.compressedPositions.push(index);
    state.compressedOrder.push(key);
  }

  state.contractAnchors = [...state.compressedOrder];
  return state;
}

function buildTraceContract(state, config, sourcePath) {
  const traceDescriptors = [...state.traceDescriptors.values()]
    .map(serializeFamily)
    .sort((left, right) => {
      if (left.target === right.target) {
        return (left.spanName ?? '').localeCompare(right.spanName ?? '');
      }
      return left.target.localeCompare(right.target);
    });

  const anchors = anchorSequence(state, config)
    .map(key => state.traceDescriptors.get(key))
    .filter(Boolean)
    .map(serializeFamily);

  return {
    format: CONTRACT_FORMAT_VERSION,
    source: {
      file: sourcePath,
      jsonEvents: state.totalJsonLines,
      traceDescriptorCount: state.traceDescriptors.size,
    },
    traceDescriptors,
    anchors,
  };
}

function normalizeSelector(selector) {
  if (!selector || typeof selector !== 'object' || Array.isArray(selector)) {
    throw new Error('milestone selectors must be objects');
  }

  const normalized = {
    target: typeof selector.target === 'string' ? selector.target : '',
    spanName: typeof selector.spanName === 'string' ? selector.spanName : '',
  };

  if (!normalized.target && !normalized.spanName) {
    throw new Error('milestone selectors must constrain at least one of target or spanName');
  }

  return normalized;
}

function selectorMatchesFamily(selector, family) {
  if (selector.target && selector.target !== family.target) return false;
  if (selector.spanName && selector.spanName !== family.spanName) return false;
  return true;
}

function isMilestoneFamily(family, selectors) {
  if (!family) return false;
  return selectors.some(selector => selectorMatchesFamily(selector, family));
}

function failInvalidConfig(configPath, message) {
  console.error(`Invalid --config file ${configPath}: ${message}`);
  process.exit(2);
}

function loadConfig(configPath) {
  if (!configPath) {
    return { milestoneSelectors: null };
  }

  let parsed;
  try {
    parsed = JSON.parse(readFileSync(configPath, 'utf8'));
  } catch (error) {
    failInvalidConfig(configPath, error instanceof Error ? error.message : String(error));
  }

  if (parsed == null || Array.isArray(parsed) || typeof parsed !== 'object') {
    failInvalidConfig(configPath, 'top-level JSON value must be an object');
  }

  if (Object.hasOwn(parsed, 'milestones') && !Array.isArray(parsed.milestones)) {
    failInvalidConfig(configPath, '"milestones" must be an array when provided');
  }

  let selectors;
  try {
    selectors = Array.isArray(parsed.milestones)
      ? parsed.milestones.map(normalizeSelector)
      : null;
  } catch (error) {
    failInvalidConfig(configPath, error instanceof Error ? error.message : String(error));
  }

  return { milestoneSelectors: selectors };
}

function inferAnchorKeys(state, config) {
  if (config.milestoneSelectors == null) {
    return state.compressedOrder.filter(key => state.traceDescriptors.get(key)?.compressedPositions.length === 1);
  }

  return state.compressedOrder.filter(key => isMilestoneFamily(state.traceDescriptors.get(key), config.milestoneSelectors));
}

function anchorSequence(state, config) {
  if (Array.isArray(state.contractAnchors)) {
    return state.contractAnchors;
  }
  return inferAnchorKeys(state, config);
}

function firstCompressedPosition(state, key) {
  return state.traceDescriptors.get(key)?.compressedPositions[0];
}

function compareFamilies(baseline, candidate, config) {
  const failures = [];
  const additions = [];

  for (const [key, family] of baseline.traceDescriptors.entries()) {
    const other = candidate.traceDescriptors.get(key);
    if (!other) {
      failures.push({
        kind: 'missing-trace-descriptor',
        family,
      });
      continue;
    }
  }

  // Sequence compatibility is evaluated on an anchor subsequence. By default,
  // anchors are singleton families inferred from the baseline. Config can
  // override this with explicit selectors for stronger, scenario-specific flow
  // contracts. Candidate ordering is checked against the first compressed
  // occurrence of each baseline anchor family so repeated candidate families do
  // not weaken or distort the contract.
  const baselineAnchors = anchorSequence(baseline, config);
  const candidateAnchorIndex = new Map(
    baselineAnchors
      .map(key => [key, firstCompressedPosition(candidate, key)])
      .filter(([, index]) => Number.isInteger(index)),
  );

  for (let index = 0; index < baselineAnchors.length - 1; index += 1) {
    const beforeKey = baselineAnchors[index];
    const afterKey = baselineAnchors[index + 1];
    if (!candidateAnchorIndex.has(beforeKey) || !candidateAnchorIndex.has(afterKey)) {
      continue;
    }

    if (candidateAnchorIndex.get(beforeKey) > candidateAnchorIndex.get(afterKey)) {
      failures.push({
        kind: 'sequence-order-changed',
        before: baseline.traceDescriptors.get(beforeKey),
        after: baseline.traceDescriptors.get(afterKey),
      });
    }
  }

  for (const [key, family] of candidate.traceDescriptors.entries()) {
    if (!baseline.traceDescriptors.has(key)) {
      additions.push(family);
    }
  }

  return { failures, additions };
}

function serializeFailure(failure) {
  if (failure.kind === 'missing-trace-descriptor') {
    return {
      kind: failure.kind,
      traceDescriptor: formatFamily(failure.family),
    };
  }

  if (failure.kind === 'sequence-order-changed') {
    return {
      kind: failure.kind,
      before: formatFamily(failure.before),
      after: formatFamily(failure.after),
    };
  }

  return failure;
}

function buildFailureReport(baseline, candidate, result) {
  const baselineSummary = baseline.source && typeof baseline.source === 'object'
    ? {
        file: typeof baseline.source.file === 'string' ? baseline.source.file : baseline.filePath,
        jsonEvents: Number.isInteger(baseline.source.jsonEvents)
          ? baseline.source.jsonEvents
          : baseline.totalJsonLines,
        traceDescriptorCount: Number.isInteger(baseline.source.traceDescriptorCount)
          ? baseline.source.traceDescriptorCount
          : baseline.traceDescriptors.size,
      }
    : {
        file: baseline.filePath,
        jsonEvents: baseline.totalJsonLines,
        traceDescriptorCount: baseline.traceDescriptors.size,
      };

  return {
    status: 'fail',
    baseline: baselineSummary,
    candidate: {
      file: candidate.filePath,
      jsonEvents: candidate.totalJsonLines,
      traceDescriptorCount: candidate.traceDescriptors.size,
    },
    failures: result.failures.map(serializeFailure),
    additions: result.additions.map(formatFamily),
  };
}

function printUsage() {
  console.error(`Usage:
  node scripts/compare-traces --export-contract contract.json [--config compare-traces.json] baseline.log
  node scripts/compare-traces [--config compare-traces.json] contract.json candidate.log

The command compares trace descriptors from a checked-in contract against a candidate Amaru run.
It fails when the candidate run removes a previously observed trace descriptor or
changes the relative order of baseline anchor traces.
Extra trace descriptors in the candidate run are allowed.

Config file format:
  {
    "milestones": [
      { "target": "amaru::consensus::chain_sync", "spanName": "decode_header" },
      { "target": "amaru::ledger::state", "spanName": "compute_stake_distribution" }
    ]
  }

When "milestones" is omitted, ordering is inferred from singleton trace descriptors in the baseline run.
If selectors are provided, the order of their first compressed occurrences becomes the contract.
If "milestones" is an empty array, order checks are disabled.

The --export-contract mode creates a compact contract snapshot from a traced run.
This is intended for CI-friendly checked-in baselines.
`);
}

function parseArgs(argv) {
  const parsed = { configPath: null, exportContractPath: null, files: [] };

  for (let index = 0; index < argv.length; index += 1) {
    const arg = argv[index];
    if (arg === '--config') {
      parsed.configPath = argv[index + 1] ?? null;
      index += 1;
      continue;
    }
    if (arg === '--export-contract') {
      parsed.exportContractPath = argv[index + 1] ?? null;
      index += 1;
      continue;
    }
    parsed.files.push(arg);
  }

  return parsed;
}

const rawArgs = process.argv.slice(2);

if (rawArgs.includes('--help') || rawArgs.includes('-h')) {
  printUsage();
  process.exit(0);
}

const args = parseArgs(rawArgs);

if (rawArgs.includes('--config') && args.configPath == null) {
  printUsage();
  process.exit(2);
}

if (rawArgs.includes('--export-contract') && args.exportContractPath == null) {
  printUsage();
  process.exit(2);
}

if (args.exportContractPath != null && args.files.length !== 1) {
  printUsage();
  process.exit(2);
}

if (args.exportContractPath == null && args.files.length !== 2) {
  printUsage();
  process.exit(2);
}
const config = loadConfig(args.configPath);

if (args.exportContractPath != null) {
  const [baselineFile] = args.files;
  const baseline = await loadTraceState(baselineFile);
  const contract = buildTraceContract(baseline, config, baselineFile);
  writeFileSync(args.exportContractPath, `${JSON.stringify(contract, null, 2)}\n`);
  process.exit(0);
}

const [baselineFile, candidateFile] = args.files;
const baseline = loadTraceContract(baselineFile);
const candidate = await loadTraceState(candidateFile);
const result = compareFamilies(baseline, candidate, config);

if (result.failures.length > 0) {
  console.log(JSON.stringify(buildFailureReport(baseline, candidate, result), null, 2));
  process.exit(1);
}

process.exit(0);