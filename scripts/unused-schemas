#!/usr/bin/env bash
# Find schema constants (from dump-traces-schema JSON) never referenced in trace_span! calls.
#
# Private schemas (public: false) are included in the registry so they appear here too.

set -euo pipefail

AMARU_BIN="${AMARU_BIN:-./target/debug/amaru}"

if [[ ! -x "$AMARU_BIN" ]]; then
    echo "Building amaru binary..." >&2
    cargo build -p amaru --bin amaru 2>&1 >&2
fi

# Get all schema paths from the compiled registry (both public and private)
all_paths=$("$AMARU_BIN" dump-traces-schema 2>&1 | jq -r '.definitions | keys[]' | sort)

total=$(echo "$all_paths" | wc -l | tr -d ' ')
unused=0

# Single pass: extract all multi-segment ::path::CONSTANT references from source.
# Exclude amaru-observability itself (schema definitions and macro doc comments
# would trivially match their own paths and produce false "used" results).
used=$(find crates simulation -name "*.rs" \
    -not -path "*/target/*" \
    -not -path "*/amaru-observability/*" \
    | xargs grep -ohE '([a-z_]+::)+[A-Z][A-Z0-9_]+' 2>/dev/null \
    | sort -u)

while IFS= read -r path; do
    if ! echo "$used" | grep -qF "$path"; then
        echo "UNUSED  $path"
        unused=$((unused + 1))
    fi
done <<< "$all_paths"

echo ""
echo "$unused unused / $total total schema constants"

if [[ $unused -gt 0 ]]; then
    exit 1
fi
